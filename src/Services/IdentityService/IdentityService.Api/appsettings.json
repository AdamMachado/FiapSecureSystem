{
  "OpenTelemetry": {
    "ServiceName": "SOAT.IdentityService.Api",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Endpoint": "http://otel-collector:4317"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },

  "Jwt": {
    "Issuer": "FiapSecureSystem.Identity",
    "Audience": "FiapSecureSystem.Api",
    "SigningKey": "dev-only-super-secret-signing-key-change-this",
    "RequireHttpsMetadata": false,
    "ValidateLifetime": true,
    "ClockSkewSeconds": 60
  },

  "Identity": {
    "AccessTokenExpirationMinutes": 15,
    "SeedUsers": [
      {
        "Id": "11111111-1111-1111-1111-111111111111",
        "Email": "admin@fiap.local",
        "DisplayName": "Admin User",
        "Password": "Admin123!",
        "IsActive": true,
        "Roles": [ "Admin" ],
        "Scopes": [ "analysis.read", "analysis.write", "report.read" ]
      },
      {
        "Id": "22222222-2222-2222-2222-222222222222",
        "Email": "analyst@fiap.local",
        "DisplayName": "Analyst User",
        "Password": "Analyst123!",
        "IsActive": true,
        "Roles": [ "Analyst" ],
        "Scopes": [ "analysis.read", "report.read" ]
      }
    ]
  },

  "AllowedHosts": "*"
}
