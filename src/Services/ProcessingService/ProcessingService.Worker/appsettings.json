{
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=fiap_secure_systems;Username=postgres;Password=postgres",
    "Schema": "processing",
    "EnableSensitiveDataLogging": false
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "ClientProvidedName": "processing-service-worker",
    "UseSsl": false,
    "PrefetchCount": 5
  },
  "Storage": {
    "BucketName": "analysis-uploads",
    "AutoCreateBucket": false
  },
  "MinIo": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o",
    "MaxOutputTokens": 3000,
    "ServiceTier": "auto",
    "EnableFallbackToDefaultServiceTier": true,
    "MaxRetries": 1,
    "TimeoutSeconds": 120
  },
  "ArchitectureAnalysis": {
    "PromptVersion": "architecture-analysis-v1",
    "Language": "pt-BR",
    "ImageDetail": "auto",
    "MinFileSizeInBytes": 1024,
    "MaxFileSizeInBytes": 10485760,
    "MinImageWidth": 300,
    "MinImageHeight": 300,
    "MaxImageWidth": 6000,
    "MaxImageHeight": 6000,
    "MaxPdfPages": 5,
    "MinExtractedTextLengthForPdf": 20,
    "RejectEncryptedPdf": true,
    "EnablePdfTextPreExtraction": true,
    "EnableDiagramHeuristics": true,
    "MaxComponents": 30,
    "MaxRisks": 15,
    "MaxRecommendations": 15,
    "MaxWarnings": 10,
    "UseCompactOutput": true
  },
  "OpenTelemetry": {
    "ServiceName": "SOAT.ProcessingService.Worker",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
