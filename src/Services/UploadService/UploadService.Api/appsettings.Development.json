{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "ProcessingService": "Debug",
      "Microsoft": "Information"
    }
  },

  "Database": {
    "EnableSensitiveDataLogging": true
  }
}
