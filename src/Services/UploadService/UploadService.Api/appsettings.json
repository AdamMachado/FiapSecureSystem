{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "OpenTelemetry": {
    "ServiceName": "SOAT.UploadService.Api",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=uploadservice;Username=postgres;Password=postgres",
    "Schema": "upload",
    "EnableSensitiveDataLogging": false
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "ClientProvidedName": "upload-service"
  },
  "Storage": {
    "BucketName": "analysis-uploads",
    "AutoCreateBucket": true
  },
  "Upload": {
    "MaxFileSizeInBytes": 10485760,
    "SupportedContentTypes": [
      "application/pdf",
      "image/png",
      "image/jpeg",
      "image/jpg"
    ]
  },
  "MinIo": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false
  },
  "AllowedHosts": "*"
}
