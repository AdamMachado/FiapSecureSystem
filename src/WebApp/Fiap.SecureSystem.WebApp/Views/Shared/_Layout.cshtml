<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FIAP Secure System</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Fiap.SecureSystem.WebApp.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="app-body">
    <header class="app-header">
        <nav class="app-navbar">
            <a class="app-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" class="app-logo" alt="FIAP Secure System" />
                <span>Secure System</span>
            </a>

            <div class="app-nav-links">
                <a asp-controller="Home" asp-action="Index">Home</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                    <a asp-controller="Analyses" asp-action="Create">Enviar diagrama</a>
                }
            </div>

            <div class="app-user-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="app-user-name">@(User.Identity?.Name ?? "Usuario")</span>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="app-logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="app-btn app-btn-secondary app-btn-compact">Sair</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Register" class="app-btn app-btn-secondary app-btn-compact">Criar conta</a>
                    <a asp-controller="Auth" asp-action="Login" class="app-btn app-btn-secondary app-btn-compact">Entrar</a>
                }
            </div>
        </nav>
    </header>

    <main class="app-main" role="main">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <span>&copy; 2026 - FIAP Secure System</span>
        <span>SOAT Tech Challenge - Hackathon</span>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
