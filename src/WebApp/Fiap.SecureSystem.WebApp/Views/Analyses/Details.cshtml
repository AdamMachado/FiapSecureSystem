@using System.Text.Json
@model AnalysisDetailsViewModel

@{
    ViewData["Title"] = "Detalhes da Análise";

    var analysisPayload = JsonSerializer.Serialize(
        Model,
        new JsonSerializerOptions(JsonSerializerDefaults.Web));
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/analysis-details.css" asp-append-version="true" />
}

<nav class="path-section">
    <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
    <a href="javascript:" class="current">Análise</a>
</nav>

<section
    class="analysis-details"
    id="analysis-details-root"
    data-status-url="@Url.Action("DetailsStatus", "Analyses", new { id = Model.Id })">
    <div class="details-header">
        <div>
            <span class="page-label">Análise</span>
            <h1 id="analysis-file-name">@Model.FileName</h1>
            <p>ID: <span id="analysis-id">@Model.Id</span></p>
        </div>
    </div>

    <div class="timeline-card">
        <h2>Status do processamento</h2>

        <div class="timeline">
            <div class="timeline-step done">
                <span><i class="fa-solid fa-check"></i></span>
                <div>
                    <strong>Recebido</strong>
                    <p id="timeline-received-text">Arquivo enviado em @Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <div class="timeline-step @((Model.StatusCssClass is "received" or "processing") ? "active" : "done")" id="timeline-processing-step">
                <span><i class="fa-solid @(Model.StatusCssClass is "received" or "processing" ? "fa-spinner status-icon-spin" : "fa-check")" id="timeline-processing-icon"></i></span>
                <div>
                    <strong>Processando</strong>
                    <p id="timeline-processing-text">@(Model.StartedAtUtc.HasValue ? $"Processamento iniciado em {Model.StartedAtUtc.Value.ToLocalTime():dd/MM/yyyy HH:mm}" : "Análise do diagrama em andamento")</p>
                </div>
            </div>

            @{
                string completedColorStatus = string.Empty;

                switch (Model.StatusCssClass)
                {
                    case "completed" :
                        completedColorStatus = "done";
                        break;
                    case "failed" :
                        completedColorStatus = "failed";
                        break;
                }
            }

            <div class="timeline-step @(completedColorStatus)" id="timeline-finished-step">
                <span><i class="fa-solid @(Model.StatusCssClass == "failed" ? "fa-xmark" : Model.StatusCssClass == "completed" ? "fa-check" : "fa-clock")" id="timeline-finished-icon"></i></span>
                <div>
                    <strong id="timeline-finished-title">@(Model.StatusCode == "failed" ? "Falha" : "Analisado")</strong>
                    <p id="timeline-finished-text">
                        @if (Model.CompletedAtUtc.HasValue)
                        {
                            @:Concluído em @Model.CompletedAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        }
                        else if (Model.FailedAtUtc.HasValue)
                        {
                            @:Falhou em @Model.FailedAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        }
                        else
                        {
                            @:Aguardando conclusão
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="info-grid">
        <div class="info-card">
            <h3>Informações</h3>
            <ul>
                <li><strong>Tipo:</strong> <span id="analysis-content-type">@Model.ContentType</span></li>
                <li><strong>Tamanho:</strong> <span id="analysis-size">@((Model.SizeInBytes / 1024d / 1024d).ToString("0.00")) MB</span></li>
                <li><strong>Enviado em:</strong> <span id="analysis-created">@Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></li>
                <li><strong>Atualizado em:</strong> <span id="analysis-updated">@Model.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></li>
            </ul>
        </div>

        <div class="info-card">
            <h3>Status</h3>
            <span class="status-pill @Model.StatusCssClass" id="analysis-status-pill">@Model.Status</span>
            <p class="mt-3 mb-0" id="analysis-failure-reason">
                @if(Model.StatusCode == "completed")
                {
                    <span>Análise concluída com sucesso</span>
                }
                else
                {
                    @Model.FailureReason
                }
            </p>
        </div>
    </div>

    <div class="report-card" id="analysis-report-card">
        <h2>Relatório</h2>

        @if (Model.HasReport)
        {
            <p id="analysis-report-description">Relatório disponível para consulta e download.</p>

            @if (TempData["DownloadReportError"] is string downloadReportError)
            {
                <partial name="_ToastMessages" model="@(new[] { new ToastMessageViewModel { Type = "warning", Message = downloadReportError, IsSticky = true } })" />
            }

            <div class="report-actions" id="analysis-report-actions">
                <a href="@Model.ReportDetailsUrl" class="app-btn app-btn-secondary" id="analysis-report-link">
                    Ver Relatório
                </a>

                <form asp-controller="Analyses" asp-action="DownloadReport" method="get" class="report-download-form" id="analysis-report-download-form">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <select name="format" class="report-format-select" aria-label="Formato do relatório">
                        <option value="pdf">PDF</option>
                        <option value="markdown">Markdown</option>
                        <option value="json">JSON</option>
                    </select>

                    <button type="submit" class="app-btn app-btn-primary">
                        Baixar Relatório
                    </button>
                </form>
            </div>
        }
        else
        {
            <p id="analysis-report-description">Disponível após a conclusão da análise.</p>

            <div class="report-actions" id="analysis-report-actions">
                <button class="app-btn app-btn-primary" disabled id="analysis-report-disabled-button">
                    Baixar Relatório
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.AssetDownloadUrl))
    {
        <div class="report-card">
            <h2>Arquivo original</h2>
            <a href="@Model.AssetDownloadUrl" class="app-btn app-btn-secondary">
                Baixar diagrama enviado
            </a>
        </div>
    }
</section>

<script id="analysis-details-bootstrap" type="application/json">@Html.Raw(analysisPayload)</script>

@section Scripts {
    <script>
        (() => {
            const root = document.getElementById("analysis-details-root");
            const bootstrap = document.getElementById("analysis-details-bootstrap");

            if (!root || !bootstrap) {
                return;
            }

            const statusUrl = root.dataset.statusUrl;

            if (!statusUrl) {
                return;
            }

            const dateFormatter = new Intl.DateTimeFormat("pt-BR", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit"
            });

            const state = {
                model: JSON.parse(bootstrap.textContent ?? "{}"),
                intervalId: null,
                isRefreshing: false
            };

            const elements = {
                fileName: document.getElementById("analysis-file-name"),
                contentType: document.getElementById("analysis-content-type"),
                size: document.getElementById("analysis-size"),
                created: document.getElementById("analysis-created"),
                updated: document.getElementById("analysis-updated"),
                statusPill: document.getElementById("analysis-status-pill"),
                failureReason: document.getElementById("analysis-failure-reason"),
                processingStep: document.getElementById("timeline-processing-step"),
                processingIcon: document.getElementById("timeline-processing-icon"),
                processingText: document.getElementById("timeline-processing-text"),
                finishedStep: document.getElementById("timeline-finished-step"),
                finishedIcon: document.getElementById("timeline-finished-icon"),
                finishedTitle: document.getElementById("timeline-finished-title"),
                finishedText: document.getElementById("timeline-finished-text"),
                reportDescription: document.getElementById("analysis-report-description"),
                reportActions: document.getElementById("analysis-report-actions")
            };

            function escapeHtml(value) {
                return String(value ?? "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll("\"", "&quot;")
                    .replaceAll("'", "&#39;");
            }

            function formatDate(value) {
                if (!value) {
                    return "";
                }

                const date = new Date(value);
                return Number.isNaN(date.getTime()) ? "" : dateFormatter.format(date);
            }

            function formatSize(sizeInBytes) {
                const size = Number(sizeInBytes ?? 0);
                return `${(size / 1024 / 1024).toFixed(2)} MB`;
            }

            function isActiveStatus(model) {
                return model.statusCssClass === "received" || model.statusCssClass === "processing";
            }

            function getProcessingIconClass(model) {
                return isActiveStatus(model)
                    ? "fa-solid fa-spinner status-icon-spin"
                    : "fa-solid fa-check";
            }

            function getFinishedIconClass(model) {
                if (model.statusCssClass === "failed") {
                    return "fa-solid fa-xmark";
                }

                if (model.statusCssClass === "completed") {
                    return "fa-solid fa-check";
                }

                return "fa-solid fa-clock";
            }

            function buildProcessingText(model) {
                if (model.startedAtUtc) {
                    return `Processamento iniciado em ${formatDate(model.startedAtUtc)}`;
                }

                return "Análise do diagrama em andamento";
            }

            function buildFinishedText(model) {
                if (model.completedAtUtc) {
                    return `Concluído em ${formatDate(model.completedAtUtc)}`;
                }

                if (model.failedAtUtc) {
                    return `Falhou em ${formatDate(model.failedAtUtc)}`;
                }

                return "Aguardando conclusão";
            }

            function buildReportActions(model) {
                if (model.hasReport && model.reportDetailsUrl && model.reportDownloadUrl) {
                    return `
                        <a href="${escapeHtml(model.reportDetailsUrl)}" class="app-btn app-btn-secondary" id="analysis-report-link">
                            Ver Relatório
                        </a>
                        <form action="${escapeHtml(model.reportDownloadUrl)}" method="get" class="report-download-form" id="analysis-report-download-form">
                            <input type="hidden" name="id" value="${escapeHtml(model.id)}" />
                            <select name="format" class="report-format-select" aria-label="Formato do Relatório">
                                <option value="pdf">PDF</option>
                                <option value="markdown">Markdown</option>
                                <option value="json">JSON</option>
                            </select>
                            <button type="submit" class="app-btn app-btn-primary">
                                Baixar Relatório
                            </button>
                        </form>
                    `;
                }

                return `
                    <button class="app-btn app-btn-primary" disabled id="analysis-report-disabled-button">
                        Baixar Relatório
                    </button>
                `;
            }

            function handleChanges(newModel) {
                console.log('handleChanges() - model:', state.model, ' newModel:', newModel);

                console.log('previous status:', state.model.statusCode, ' new status:', newModel.statusCode);

                if(state.model.statusCode != 'processing' && newModel.statusCode == 'processing'){
                    let text = '<b>Processando</b> análise iniciada.';

                    if(newModel.startedAtUtc)
                        text += '<br/>Iniciado em ' + formatDate(newModel.startedAtUtc);

                    window.appToast.info(text);
                }
                else if(state.model.statusCode != 'completed' && newModel.statusCode == 'completed'){
                    let text = '<b>Concluído</b> análise finalizada.';

                    if(newModel.completedAtUtc)
                        text += '<br/>Concluído em ' + formatDate(newModel.completedAtUtc);

                    window.appToast.success(text);
                }
                else if(state.model.statusCode != 'failed' && newModel.statusCode == 'failed'){
                    let text = '<b>Erro</b> análise não finalizada.';

                    if(newModel.failedAtUtc)
                        text += '<br/>Falhou em ' + formatDate(newModel.failedAtUtc);

                    window.appToast.error(text);
                }
            }

            function render(model) {
                state.model = model;

                if (elements.fileName) {
                    elements.fileName.textContent = model.fileName ?? "";
                }

                if (elements.contentType) {
                    elements.contentType.textContent = model.contentType ?? "";
                }

                if (elements.size) {
                    elements.size.textContent = formatSize(model.sizeInBytes);
                }

                if (elements.created) {
                    elements.created.textContent = formatDate(model.createdAtUtc);
                }

                if (elements.updated) {
                    elements.updated.textContent = formatDate(model.updatedAtUtc);
                }

                if (elements.statusPill) {
                    elements.statusPill.className = `status-pill ${model.statusCssClass ?? ""}`.trim();
                    elements.statusPill.textContent = model.status ?? "";
                }

                if(model.statusCode == "completed"){
                    elements.failureReason.textContent = "Análise concluída com sucesso.";
                }
                else if (elements.failureReason) {
                    elements.failureReason.textContent = model.failureReason ?? "";
                }

                if (elements.processingStep) {
                    elements.processingStep.className = `timeline-step ${(model.statusCssClass === "completed" || model.statusCssClass === "failed") ? "done" : ""}`.trim();
                }

                if (elements.processingIcon) {
                    elements.processingIcon.className = getProcessingIconClass(model);
                }

                if (elements.processingText) {
                    elements.processingText.textContent = buildProcessingText(model);
                }

                if (elements.finishedStep) {
                    let finishedStepClass = 'timeline-step ';

                    if(model.statusCode == 'received' || model.statusCode == 'processing')
                        finishedStepClass += 'active';
                    else if(model.statusCode == 'completed')
                        finishedStepClass += 'done';
                    else if(model.statusCode == 'failed')
                        finishedStepClass += 'done failed';

                    elements.finishedStep.className = finishedStepClass;
                }

                if (elements.finishedIcon) {
                    elements.finishedIcon.className = getFinishedIconClass(model);
                }

                if (elements.finishedTitle) {
                    if(model.statusCode == 'failed')
                        elements.finishedTitle.textContent = "Falha";
                    else
                        elements.finishedTitle.textContent = "Analisado";
                }

                if (elements.finishedText) {
                    elements.finishedText.textContent = buildFinishedText(model);
                }

                if (elements.reportDescription) {
                    elements.reportDescription.textContent = model.hasReport
                        ? "Relatório disponível para consulta e download."
                        : "Disponível após a conclusão da análise.";
                }

                if (elements.reportActions) {
                    elements.reportActions.innerHTML = buildReportActions(model);
                }

                syncPolling();
            }

            function stopPolling() {
                if (state.intervalId !== null) {
                    window.clearInterval(state.intervalId);
                    state.intervalId = null;
                }
            }

            async function refreshDetails() {
                if (state.isRefreshing || !isActiveStatus(state.model)) {
                    if (!isActiveStatus(state.model)) {
                        stopPolling();
                    }

                    return;
                }

                state.isRefreshing = true;

                try {
                    const response = await fetch(statusUrl, {
                        method: "GET",
                        headers: {
                            "Accept": "application/json"
                        }
                    });

                    if (!response.ok) {
                        return;
                    }

                    const nextModel = await response.json();
                    handleChanges(nextModel);
                    render(nextModel);
                } catch {
                } finally {
                    state.isRefreshing = false;
                }
            }

            function syncPolling() {
                if (!isActiveStatus(state.model)) {
                    stopPolling();
                    return;
                }

                if (state.intervalId !== null) {
                    return;
                }

                state.intervalId = window.setInterval(refreshDetails, 3000);
            }

            render(state.model);
            void refreshDetails();

            window.addEventListener("beforeunload", () => {
                stopPolling();
            });
        })();
    </script>
}
