@model AnalysisCreateViewModel

@{
    ViewData["Title"] = "Enviar Diagrama";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/upload.css" asp-append-version="true" />
}

<nav class="path-section"> 
    <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
    <a href="javascript:" class="current">Upload</a>
</nav>

<section class="upload-page">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <partial name="_ToastMessages" model="@(new[] { new ToastMessageViewModel { Type = "error", Message = Model.ErrorMessage!, IsSticky = true } })" />
    }

    <div class="upload-header">
        <div>
            <span class="page-label">Nova análise</span>
            <h1>Enviar Diagrama</h1>
            <p>Envie um PDF, PNG ou JPEG para análise automática.</p>
        </div>
    </div>

    <form asp-controller="Analyses" asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
        @Html.AntiForgeryToken()

        <div class="upload-card">
            <input type="file" name="file" id="fileInput" class="file-input" accept=".pdf,.png,.jpg,.jpeg,application/pdf,image/png,image/jpeg" required />

            <label class="dropzone" id="dropzone" for="fileInput">
                <div class="drop-content">
                    <span class="icon">📂</span>
                    <strong>Arraste seu arquivo aqui</strong>
                    <p>ou clique para selecionar</p>
                    <small>PDF, PNG ou JPEG</small>
                </div>
            </label>

            <div class="file-preview" id="filePreview" style="display:none;">
                <strong id="fileName"></strong>
                <span id="fileSize"></span>
            </div>
        </div>

        <div class="upload-actions">
            <button type="submit" class="app-btn app-btn-primary is-disabled" id="submitButton" aria-disabled="true">
                Enviar para Análise
            </button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        const dropzone = document.getElementById('dropzone');
        const input = document.getElementById('fileInput');
        const preview = document.getElementById('filePreview');
        const fileName = document.getElementById('fileName');
        const fileSize = document.getElementById('fileSize');
        const uploadForm = document.getElementById('uploadForm');
        const submitButton = document.getElementById('submitButton');

        input.addEventListener('change', (e) => {
            const file = e.target.files[0];
            updateSelectedFile(file);
        });

        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('dragging');
        });

        dropzone.addEventListener('dragleave', () => {
            dropzone.classList.remove('dragging');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('dragging');

            const file = e.dataTransfer.files[0];
            input.files = e.dataTransfer.files;

            updateSelectedFile(file);
        });

        let isDelayedSubmit = false;

        uploadForm.addEventListener('submit', (e) => {
            if (isDelayedSubmit) {
                return;
            }

            if (!input.files || input.files.length === 0) {
                e.preventDefault();

                window.appToast.warning('Nenhum arquivo selecionado para upload.');
                highlightUploadSection();

                return;
            }

            e.preventDefault();

            submitButton.disabled = true;
            submitButton.innerText = 'Enviando...';
            window.appToast.info('Realizando envio do arquivo...');

            setTimeout(() => {
                isDelayedSubmit = true;
                uploadForm.submit();
            }, 300);
        });

        function updateSelectedFile(file) {
            if (file) {
                showFile(file);
                setSubmitEnabled(true);
                clearUploadHighlight();
                return;
            }

            preview.style.display = 'none';
            fileName.innerText = '';
            fileSize.innerText = '';
            setSubmitEnabled(false);
        }

        function showFile(file) {
            preview.style.display = 'block';
            fileName.innerText = file.name;

            let fileSizeText = (file.size / 1024 / 1024).toFixed(2) + " MB"
            fileSize.innerText = fileSizeText;

            window.appToast.info('Arquivo selecionado<br/><b>Arquivo:</b> ' + file.name + '<br/><b>Tamanho:</b> ' + fileSizeText);
        }

        function setSubmitEnabled(enabled) {
            submitButton.classList.toggle('is-disabled', !enabled);
            submitButton.setAttribute('aria-disabled', String(!enabled));
        }

        function highlightUploadSection() {
            dropzone.classList.add('upload-highlight');
        }

        function clearUploadHighlight() {
            dropzone.classList.remove('upload-highlight');
        }

        setSubmitEnabled(false);
    </script>
}
