@model ReportDetailsViewModel

@{
    ViewData["Title"] = "Relatório";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/report.css" asp-append-version="true" />
}

<section class="report-page">
    <div class="report-header">
        <div>
            <span class="page-label">Relatório técnico</span>
            <h1>Resultado da análise</h1>
            <p>Dados do relatório retornados pelo ApiGateway para a análise @Model.AnalysisId.</p>
        </div>

        <div class="report-actions">
            <a asp-controller="Analyses" asp-action="Details" asp-route-id="@Model.AnalysisId" class="app-btn app-btn-secondary">
                Voltar
            </a>

            @if (Model.Files.Any(file => file.Format == "PDF"))
            {
                <a href="@Model.Files.First(file => file.Format == "PDF").DownloadUrl" class="app-btn app-btn-primary">
                    Download PDF
                </a>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <div class="report-grid">
        <div class="report-card summary-card">
            <span>Componentes</span>
            <strong>@Model.ComponentCount</strong>
            <p>Itens encontrados no payload `analysisData`.</p>
        </div>

        <div class="report-card summary-card">
            <span>Riscos</span>
            <strong>@Model.RiskCount</strong>
            <p>Entradas localizadas no payload do relatório.</p>
        </div>

        <div class="report-card summary-card">
            <span>Recomendações</span>
            <strong>@Model.RecommendationCount</strong>
            <p>Itens mapeados automaticamente a partir do JSON retornado.</p>
        </div>
    </div>

    <div class="report-content">
        <div class="report-card">
            <h2>Resumo executivo</h2>
            <p>Este layout foi mantido e agora recebe dados reais do ApiGateway. A apresentação detalhada do relatório pode evoluir depois sem alterar o client HTTP.</p>
        </div>

        <div class="report-card">
            <h2>Arquivos gerados</h2>

            @if (Model.Files.Count == 0)
            {
                <p>Nenhum arquivo associado foi retornado.</p>
            }
            else
            {
                <div class="report-list">
                    @foreach (var file in Model.Files)
                    {
                        <div class="report-item">
                            <strong>@file.FileName</strong>
                            <span>@file.Format • @file.ContentType • gerado em @file.GeneratedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            <a href="@file.DownloadUrl" class="link mt-2">Baixar →</a>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="report-card">
            <h2>Metadados</h2>
            <div class="risk-list">
                <div class="risk-item medium">
                    <span>ID</span>
                    <div>
                        <strong>@Model.ReportId</strong>
                        <p>Identificador do relatório retornado pelo gateway.</p>
                    </div>
                </div>

                <div class="risk-item low">
                    <span>Criado</span>
                    <div>
                        <strong>@Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                        <p>Data de criação do relatório.</p>
                    </div>
                </div>

                <div class="risk-item low">
                    <span>Atualizado</span>
                    <div>
                        <strong>@Model.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                        <p>Última atualização do relatório.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="report-card">
            <h2>Payload bruto</h2>
            <pre class="mb-0"><code>@Model.AnalysisDataJson</code></pre>
        </div>
    </div>
</section>
