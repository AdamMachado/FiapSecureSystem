@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/dashboard.css" asp-append-version="true" />
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <span class="page-label">Visão geral</span>
            <h1>Dashboard</h1>
            <p>Acompanhe as análises enviadas e o status do pipeline.</p>
        </div>

        <a asp-controller="Analyses" asp-action="Create" class="app-btn app-btn-primary">
            Enviar diagrama
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <div class="summary-grid">
        <div class="summary-card">
            <span>Total</span>
            <strong>@Model.TotalAnalyses</strong>
            <p>Análises criadas</p>
        </div>

        <div class="summary-card">
            <span>Processando</span>
            <strong>@Model.ProcessingAnalyses</strong>
            <p>Em andamento</p>
        </div>

        <div class="summary-card">
            <span>Analisadas</span>
            <strong>@Model.CompletedAnalyses</strong>
            <p>Relatórios disponíveis</p>
        </div>

        <div class="summary-card danger">
            <span>Erro</span>
            <strong>@Model.FailedAnalyses</strong>
            <p>Falhas encontradas</p>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header-row">
            <div>
                <h2>Últimas análises</h2>
                <p>Histórico recente dos diagramas enviados.</p>
            </div>
        </div>

        <div class="analysis-list">
            @if (Model.RecentAnalyses.Count == 0)
            {
                <div class="analysis-row">
                    <div class="analysis-info">
                        <strong>Nenhuma análise encontrada</strong>
                        <span>Envie um diagrama para iniciar o pipeline.</span>
                    </div>
                </div>
            }
            else
            {
                @foreach (var analysis in Model.RecentAnalyses)
                {
                    <div class="analysis-row">
                        <div class="analysis-info">
                            <strong>@analysis.FileName</strong>
                            <span>Enviado em @analysis.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") • @analysis.ContentType</span>
                        </div>

                        <div class="analysis-meta">
                            <span class="status-pill @analysis.StatusCssClass">@analysis.Status</span>
                            @if (analysis.HasReport)
                            {
                                <a asp-controller="Reports" asp-action="Details" asp-route-analysisId="@analysis.Id" class="link">
                                    Ver relatório →
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Analyses" asp-action="Details" asp-route-id="@analysis.Id" class="link">
                                    Ver detalhes →
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>
