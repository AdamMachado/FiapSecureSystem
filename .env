ASPNETCORE_ENVIRONMENT=Development

UPLOAD_API_PORT=8080

POSTGRES_DB=uploadservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_ENABLE_SENSITIVE_DATA_LOGGING=false

UPLOAD_DATABASE_SCHEMA=upload
PROCESSING_DATABASE_SCHEMA=processing
REPORT_DATABASE_SCHEMA=report

PGADMIN_DEFAULT_EMAIL=admin@fiapsecure.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USE_SSL=false
RABBITMQ_PREFETCH_COUNT=10

RABBITMQ_UPLOAD_CLIENT_PROVIDED_NAME=upload-service
RABBITMQ_REPORT_CLIENT_PROVIDED_NAME=report-service
RABBITMQ_PROCESSING_CLIENT_PROVIDED_NAME=processing-service

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=analysis-uploads
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
STORAGE_AUTO_CREATE_BUCKET=true

UPLOAD_MAX_FILE_SIZE_BYTES=10485760

OTEL_SERVICE_NAME=UploadService.Api
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318